<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.simpleschedules.transcribe-menubar</string>

    <!-- Paths are filled in by install-menubar.sh. -->
    <key>ProgramArguments</key>
    <array>
        <string>__VENV_PY__</string>
        <string>__SCRIPT__</string>
    </array>

    <!-- A menu-bar app: launch at login and keep it alive if it dies. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__LOG__</string>
    <key>StandardErrorPath</key>
    <string>__LOG__</string>

    <key>WorkingDirectory</key>
    <string>__APPDIR__</string>
</dict>
</plist>
